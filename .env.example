# =============================================
# Wise Pro Academy — Empresa AI — variaveis de ambiente
# Copie esse arquivo pra .env e preencha os valores NA CALL (STEP 1 do dashboard).
# NUNCA comitar o .env (ja esta no .gitignore). Chaves escrubadas de tudo que for salvo.
# =============================================

# --- Supabase do David (criar projeto proprio em supabase.com) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# senha do banco / connection string OU Management PAT (pro agente criar tabelas sozinho)
SUPABASE_DB_PASSWORD=
SUPABASE_MANAGEMENT_PAT=
# Espelhos PUBLICOS (nao-secretos) que o frontend Next.js usa no client/runtime.
# NEXT_PUBLIC_SUPABASE_URL = mesmo valor de SUPABASE_URL. ANON_KEY = mesmo de SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- GitHub ---
GITHUB_TOKEN=

# --- Vercel (ADR = SIM: site + landing + portal multiusuario) ---
VERCEL_TOKEN=

# --- Stripe (pagamento dos 3 produtos, USD) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (e-mail de recuperacao de carrinho, free ate 3k/mes) ---
RESEND_API_KEY=

# --- WhatsApp (recuperacao ~3h depois + atendente) — Stevo OU Z-API ---
WHATSAPP_PROVIDER=
WHATSAPP_TOKEN=
WHATSAPP_NUMBER=

# --- Pedro / Me Ensina AI Solutions (CRM liberado pro David) ---
PEDRO_API_URL=
PEDRO_API_TOKEN=

# --- Anthropic (claude.ai/console) ---
ANTHROPIC_API_KEY=
