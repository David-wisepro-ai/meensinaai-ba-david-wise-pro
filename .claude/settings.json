{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git fetch:*)",
      "Bash(git rebase:*)",
      "Bash(date:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(open:*)",
      "Bash(echo:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(brew:*)",
      "Bash(gh:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Read(*)",
      "Edit(*)",
      "Edit(.claude/commands/**)",
      "Edit(wiki/**)",
      "Edit(CLAUDE.md)",
      "Edit(MEMORY.md)",
      "Write(*)",
      "Write(.claude/commands/**)",
      "Write(wiki/**)",
      "Write(CLAUDE.md)",
      "Write(MEMORY.md)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Task(*)"
    ],
    "deny": [
      "Edit(.env*)",
      "Edit(.claude/settings.local.json)",
      "Edit(.credentials/**)",
      "Write(.env*)",
      "Write(.claude/settings.local.json)",
      "Write(.credentials/**)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/preflight-guard.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/ledger-gate.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
